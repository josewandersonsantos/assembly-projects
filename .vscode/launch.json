{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug NASM Assembly",
      "type": "cppdbg",
      "request": "launch",
      // "program": "${workspaceFolder}/x86/src/print_sequence/print_sequence",
      // "program": "${workspaceFolder}/x86/src/calculator/calculator",
      "program": "${workspaceFolder}/x86/src/jokenpo/jokenpo",
      "args": [],
      "stopAtEntry": true,
      // "cwd": "${workspaceFolder}/x86/src/print_sequence",
      // "cwd": "${workspaceFolder}/x86/src/calculator",
      "cwd": "${workspaceFolder}/x86/src/jokenpo",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
          {
              "description": "Enable pretty-printing for gdb",
              "text": "-enable-pretty-printing",
              "ignoreFailures": true
          }
      ],
      "preLaunchTask": "Build Assembly"
    },
    {
      "name": "QEMU Cortex-M3",
      "type": "cppdbg",
      "svdPath": "${workspaceFolder}/ARM/src/Blink/STM32F100.svd",
      "request": "launch",
      "stopAtEntry": true,
      "miDebuggerServerAddress": "localhost:1234",
      "cwd": "${workspaceFolder}/ARM/src/Blink/",
      "program": "${workspaceFolder}/ARM/src/Blink/main.elf",
      // "miDebuggerPath": "arm-none-eabi-gdb.exe",
      "miDebuggerPath": "gdb-multiarch",
      "setupCommands": [
          {
            "description": "Pretty print",
            "text": "-enable-pretty-printing",
            "ignoreFailures": true
          },
          // {
          //   "description": "Connect host",
          //   "text": "target remote localhost:1234",
          //   "ignoreFailures": true
          // },
          {
            "description": "Load symbol file",
            "text": "file ${workspaceFolder}/ARM/src/Blink/main.elf",
            "ignoreFailures": true
          },
          {
            "description": "Load firmware",
            "text": "load",
            "ignoreFailures": true
          },
          {
              "description": "Reset target",
              "text": "monitor system_reset",
              "ignoreFailures": true
          },
          {
              "description": "Break entry point",
              "text": "break Reset_Handler",
              "ignoreFailures": true
          },
          {
              "description": "Continue entry point",
              "text": "continue",
              "ignoreFailures": true
          }
      ],

      "preLaunchTask": "Run QEMU (GDB Server)",
      // "preLaunchTask": "Run QEMU ARM",
      "postDebugTask": "Stop QEMU ARM"
    }
  ]
}